    "ioredis": "^5.10.0",
    "kafkajs": "^2.2.4",
    "nodemailer": "^8.0.3",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.20",
    "typeorm-transactional": "^0.5.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
