{
  "name": "@chat-system/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "docker:auth:up": "docker-compose -f ../docker-compose.auth.yml up -d",
    "docker:auth:down": "docker-compose -f ../docker-compose.auth.yml down",
    "docker:auth:logs": "docker-compose -f ../docker-compose.auth.yml logs -f",
    "docker:auth:up:build": "docker-compose -f ../docker-compose.auth.yml up -d --build",
    "docker:messaging:up": "docker-compose -f ../docker-compose.messaging.yml up -d",
    "docker:messaging:down": "docker-compose -f ../docker-compose.messaging.yml down",
    "docker:messaging:logs": "docker-compose -f ../docker-compose.messaging.yml logs -f",
    "docker:messaging:up:build": "docker-compose -f ../docker-compose.messaging.yml up -d --build",
    "docker:channel:up": "docker-compose -f ../docker-compose.channel.yml up -d",
    "docker:channel:down": "docker-compose -f ../docker-compose.channel.yml down",
    "docker:channel:logs": "docker-compose -f ../docker-compose.channel.yml logs -f",
    "docker:channel:up:build": "docker-compose -f ../docker-compose.channel.yml up -d --build",
    "docker:api-gateway:up": "docker-compose -f ../docker-compose.api-gateway.yml up -d",
    "docker:api-gateway:up:build": "docker-compose -f ../docker-compose.api-gateway.yml up -d --build",
    "docker:api-gateway:down": "docker-compose -f ../docker-compose.api-gateway.yml down",
    "docker:api-gateway:logs": "docker-compose -f ../docker-compose.api-gateway.yml logs -f",
    "docker:chat:up:build": "docker-compose -f ../docker-compose.chat.yml up -d --build",
    "docker:chat:up": "docker-compose -f ../docker-compose.chat.yml up -d",
    "docker:chat:down": "docker-compose -f ../docker-compose.chat.yml down",
    "docker:chat:logs": "docker-compose -f ../docker-compose.chat.yml logs -f",
    "docker:presence:up": "docker-compose -f ../docker-compose.presence.yml up -d",
    "docker:presence:up:build": "docker-compose -f ../docker-compose.presence.yml up -d --build",
    "docker:presence:down": "docker-compose -f ../docker-compose.presence.yml down",
    "docker:presence:logs": "docker-compose -f ../docker-compose.presence.yml logs -f",
    "docker:delivery:up": "docker-compose -f ../docker-compose.delivery.yml up -d",
    "docker:delivery:up:build": "docker-compose -f ../docker-compose.delivery.yml up -d --build",
    "docker:delivery:down": "docker-compose -f ../docker-compose.delivery.yml down",
    "docker:delivery:logs": "docker-compose -f ../docker-compose.delivery.yml logs -f",
    "docker:all:up": "docker-compose -f ../docker-compose.auth.yml -f ../docker-compose.messaging.yml -f ../docker-compose.channel.yml -f ../docker-compose.api-gateway.yml -f ../docker-compose.chat.yml -f ../docker-compose.presence.yml -f ../docker-compose.delivery.yml up -d",
    "docker:all:up:build": "docker-compose -f ../docker-compose.auth.yml -f ../docker-compose.messaging.yml -f ../docker-compose.channel.yml -f ../docker-compose.api-gateway.yml -f ../docker-compose.chat.yml -f ../docker-compose.presence.yml -f ../docker-compose.delivery.yml up -d --build",
    "docker:all:down": "docker-compose -f ../docker-compose.auth.yml -f ../docker-compose.messaging.yml -f ../docker-compose.channel.yml -f ../docker-compose.api-gateway.yml -f ../docker-compose.chat.yml -f ../docker-compose.presence.yml -f ../docker-compose.delivery.yml down",
    "docker:all:logs": "docker-compose -f ../docker-compose.auth.yml -f ../docker-compose.messaging.yml -f ../docker-compose.channel.yml -f ../docker-compose.api-gateway.yml -f ../docker-compose.chat.yml -f ../docker-compose.presence.yml -f ../docker-compose.delivery.yml logs -f",
    "docker:k8s:build:all": "docker build -f services/auth/Dockerfile -t chat-system/auth:dev . && docker build -f services/channel/Dockerfile -t chat-system/channel:dev . && docker build -f services/chat/Dockerfile -t chat-system/chat:dev . && docker build -f services/presence/Dockerfile -t chat-system/presence:dev . && docker build -f services/delivery/Dockerfile -t chat-system/delivery:dev . && docker build -f services/api-gateway/Dockerfile -t chat-system/api-gateway:dev . && docker build -f services/messaging/Dockerfile.api -t chat-system/messaging-api:dev . && docker build -f services/messaging/Dockerfile.worker -t chat-system/messaging-worker:dev .",
    "k8s:secrets:sync": "node tools/k8s-sync-secrets.js",
    "k8s:infra:up": "kubectl apply -f ../k8s/namespaces/infra.yaml -f ../k8s/infra/postgres/ -f ../k8s/infra/redis/ -f ../k8s/infra/kafka/",
    "k8s:apps:up": "kubectl apply -f ../k8s/namespaces/apps.yaml -f ../k8s/apps/auth/ -f ../k8s/apps/channel/ -f ../k8s/apps/presence/ -f ../k8s/apps/delivery/configmap.yaml -f ../k8s/apps/delivery/service.yaml -f ../k8s/apps/delivery/deployment.yaml -f ../k8s/apps/messaging/ -f ../k8s/apps/chat/ -f ../k8s/apps/api-gateway/",
    "k8s:ingress:install": "helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx 2>/dev/null; helm repo update && helm upgrade --install ingress-nginx ingress-nginx/ingress-nginx --namespace ingress-nginx --create-namespace --set controller.service.type=LoadBalancer",
    "k8s:ingress:apply": "kubectl apply -f ../k8s/ingress/",
    "k8s:step6:up": "npm run k8s:ingress:install && npm run k8s:ingress:apply",
    "k8s:all:up": "npm run k8s:infra:up && npm run k8s:secrets:sync && npm run k8s:apps:up",
    "k8s:apps:restart": "kubectl rollout restart deployment/auth deployment/channel deployment/presence deployment/delivery deployment/messaging-api deployment/messaging-worker deployment/chat deployment/api-gateway -n apps",
    "k8s:status": "kubectl get pods -n infra && kubectl get pods -n apps"
  },
  "private": true,
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/eslint": "^22.4.4",
    "@nx/js": "22.4.4",
    "@nx/nest": "^22.4.4",
    "@nx/node": "22.4.4",
    "@nx/web": "22.4.4",
    "@nx/webpack": "22.4.4",
    "@nx/workspace": "22.4.4",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express-http-proxy": "^1.6.7",
    "@types/http-proxy-middleware": "^0.19.3",
    "@types/node": "20.19.9",
    "@types/nodemailer": "^7.0.11",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "~8.57.0",
    "nx": "22.4.4",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.3.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.14",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cockatiel": "^3.2.1",
    "cookie-parser": "^1.4.7",
    "express-http-proxy": "^2.1.2",
    "handlebars": "^4.7.8",
