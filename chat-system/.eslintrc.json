{
    "root": true,
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": 2021,
        "sourceType": "module"
    },
    "ignorePatterns": [
        "dist",
        "tmp",
        "node_modules"
    ],
    "plugins": [
        "@typescript-eslint"
    ],
    "overrides": [
        {
            "files": [
                "*.ts",
                "*.tsx",
                "*.js",
                "*.jsx"
            ],
            "rules": {
                "no-console": "error",
                "@typescript-eslint/no-unused-vars": [
                    "warn"
                ]
            }
        }
    ]
}