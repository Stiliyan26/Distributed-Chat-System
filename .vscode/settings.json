{
  // Tailwind / PostCSS at-rules (@apply, @tailwind, @layer) — built-in CSS validator
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",

  // TypeScript/JavaScript automatic import updates
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",

  // Use the app’s TypeScript for the language service (import-on-move + @/ paths need this project TS)
  "typescript.tsdk": "nexus-ui/node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  // NO file extensions in imports (TypeScript standard)
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.preferences.importModuleSpecifierEnding": "minimal",
  "javascript.preferences.importModuleSpecifierEnding": "minimal",

  // Enable auto-imports
  "typescript.suggest.autoImports": true,
  "javascript.suggest.autoImports": true,

  // Nx-specific settings
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/tmp": true
  },

  // Better auto-import organization
  "typescript.preferences.includePackageJsonAutoImports": "on",

  // Format on save (optional, but recommended)
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  }
}
