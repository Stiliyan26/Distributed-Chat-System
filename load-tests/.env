# Copy to `.env` and adjust (`.env` is gitignored).
#   cp .env.example .env
#
# API gateway base URL (no trailing slash).
LOAD_TEST_BASE_URL=http://localhost:3000

# Fixture user — fill after `npm run prepare:fixture` or use your own test account.
LOAD_TEST_EMAIL=lt_mp4gy1v68d6o@example.com
LOAD_TEST_PASSWORD=Password123!

# Channel UUID for k6 messages when reusing a prepared user (optional; k6 messages can auto-create).
LOAD_TEST_CHANNEL_ID=019e22de-ffcb-713e-a0c3-3f30f60cd5f2

# Optional: full access cookie line from prepare-fixture (e.g. for manual debugging only).
# LOAD_TEST_ACCESS_COOKIE=

# --- k6 auth (POST /api/auth/login) ---
LOAD_TEST_AUTH_VUS=50
LOAD_TEST_AUTH_DURATION=2m

# --- k6 channels (GET /api/channels/user) ---
LOAD_TEST_CHANNELS_VUS=50
LOAD_TEST_CHANNELS_DURATION=2m

# --- k6 messages (POST /api/messages) ---
LOAD_TEST_MSG_RATE=100
LOAD_TEST_MSG_DURATION=2m
LOAD_TEST_MSG_PRE_VUS=80
LOAD_TEST_MSG_MAX_VUS=250

# --- socket.io soak ---
LOAD_TEST_CLIENTS=100
LOAD_TEST_DURATION_SEC=0

