# Copy to `.env` and adjust (`.env` is gitignored).
# Or run once: `npm run bootstrap` then `npm run prepare:fixture` (needs API up).
#
# API gateway base URL (no trailing slash).
LOAD_TEST_BASE_URL=http://localhost:3000

# Fixture user — fill after `npm run prepare:fixture` or use your own test account.
LOAD_TEST_EMAIL=
LOAD_TEST_PASSWORD=Password123!

# Channel UUID for k6 messages when reusing a prepared user (optional; k6 messages can auto-create).
LOAD_TEST_CHANNEL_ID=

LOAD_TEST_ACCESS_COOKIE=

# --- k6 auth (POST /api/auth/login) ---
LOAD_TEST_AUTH_VUS=50
LOAD_TEST_AUTH_DURATION=2m
# p95 http_req_duration cap (ms). Default 30000 suits local Docker + 50 VUs; lower for strict gates.
LOAD_TEST_AUTH_P95_MS=30000
# Optional: max failure rates (decimal string, e.g. 0.01 = 1%)
# LOAD_TEST_AUTH_FAIL_RATE_MAX=0.01
# LOAD_TEST_AUTH_CHECK_FAIL_RATE_MAX=0.01

# --- k6 channels (GET /api/channels/user) ---
LOAD_TEST_CHANNELS_VUS=50
LOAD_TEST_CHANNELS_DURATION=2m

# --- k6 messages (POST /api/messages) ---
LOAD_TEST_MSG_RATE=100
LOAD_TEST_MSG_DURATION=2m
LOAD_TEST_MSG_PRE_VUS=80
LOAD_TEST_MSG_MAX_VUS=250

# --- socket.io soak (solo channel per client) ---
LOAD_TEST_CLIENTS=100
LOAD_TEST_DURATION_SEC=0

# --- socket.io group broadcast (Option A: fan-out per channel) ---
# Dev-friendly defaults in script: 5 channels × 20 members. Diploma demo: 20 × 50 (heavy).
LOAD_TEST_CHANNEL_COUNT=5
LOAD_TEST_MEMBERS_PER_CHANNEL=20
LOAD_TEST_BROADCAST_WAIT_MS=25000
LOAD_TEST_JOIN_SETTLE_MS=1500
LOAD_TEST_MIN_DELIVERY_RATE=0.99
LOAD_TEST_MIN_CONNECT_RATE=0.99
LOAD_TEST_PROVISION_BATCH=8
